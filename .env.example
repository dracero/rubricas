# ============================================================
# RubricAI — Variables de Entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# ------------------------------------------------------------
# CLAVES DE IA (obligatorias)
# ------------------------------------------------------------

# Google Gemini API Key — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API Key — https://platform.openai.com/api-keys
# Usado por LiteLLM para GPT-4o-mini (generación, evaluación, embeddings)
OPENAI_API_KEY=

# ------------------------------------------------------------
# BASE DE DATOS VECTORIAL — Qdrant
# ------------------------------------------------------------

# VECTOR_MODE: server | disk | memory
#   server → usa QDRANT_URL + QDRANT_API_KEY (producción)
#   disk   → persiste localmente en ./qdrant_data (desarrollo sin internet)
#   memory → solo RAM, se pierde al reiniciar (pruebas rápidas)
VECTOR_MODE=server

# Solo necesario si VECTOR_MODE=server
QDRANT_URL=
QDRANT_API_KEY=

# ------------------------------------------------------------
# BASE DE DATOS DE AUTENTICACIÓN — MongoDB Atlas
# ------------------------------------------------------------

# URI de conexión a MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/
# Obtené la URI en Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Nombre de la base de datos (se crea automáticamente si no existe)
MONGODB_DB=rubricai_auth

# ------------------------------------------------------------
# AUTENTICACIÓN — JWT
# ------------------------------------------------------------

# Clave secreta para firmar los JWT. Usá una cadena aleatoria larga.
# Generá una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga

# Tiempo de expiración del token en minutos (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# AUTENTICACIÓN — Modo y Proveedores OAuth2
# ------------------------------------------------------------

# AUTH_MODE controla qué proveedores se muestran en el login.
# Valores: LOCAL | GOOGLE | MICROSOFT | OAUTH2 | (vacío = mostrar todos)
AUTH_MODE=

# URL del frontend (usada en el redirect post-OAuth)
FRONTEND_URL=http://localhost:5173

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ------------------------------------------------------------
# SERVIDOR BACKEND
# ------------------------------------------------------------

ORCHESTRATOR_HOST=localhost
ORCHESTRATOR_PORT=8000

# ------------------------------------------------------------
# OBSERVABILIDAD — LangSmith (opcional)
# ------------------------------------------------------------

# Obtené tu API key en https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rubricas_qdrant_system

# Activar trazabilidad: true | false
LANGSMITH_TRACING=false
LANGSMITH_TRACING_V2=false
LANGCHAIN_CALLBACKS_BACKGROUND=false
LANGCHAIN_VERBOSE=false

# ------------------------------------------------------------
# ENCODING (Linux/Ubuntu — generalmente no hace falta cambiar)
# ------------------------------------------------------------

PYTHONUTF8=1
PYTHONIOENCODING=utf-8
UV_LINK_MODE=copy
