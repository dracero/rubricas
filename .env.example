# API Keys - Copy this file to .env and fill in your keys

# Groq API Key (required for all agents and orchestrator)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Qdrant Cloud Configuration (required for vector database)
# Get your credentials from: https://cloud.qdrant.io/
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# LangSmith (optional - for tracing and debugging)
# Get your key from: https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=rubricas_qdrant_system
LANGSMITH_TRACING=true

# LiteLLM / Groq Configuration (optional - for rate limiting and retries)
LITELLM_NUM_RETRIES=10
LITELLM_RETRY_AFTER_SLEEP=5
LITELLM_TPM_LIMIT=7500

# Orchestrator Model (optional - defaults to llama-3.3-70b-versatile)
ORCHESTRATOR_MODEL=llama-3.3-70b-versatile
